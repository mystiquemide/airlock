# ── Band AI Integration ────────────────────────────────────────────────────────
BAND_ROOM_ID=your_band_room_id_here
BAND_AGENT_API_KEY=band_a_your_key_here
AIRLOCK_CHAT_ID=your_chat_id_here

# Client-side Band room link (ledger frontend)
NEXT_PUBLIC_BAND_ROOM_ID=your_band_room_id_here

# ── Featherless AI ─────────────────────────────────────────────────────────────
FEATHERLESS_API_KEY=your_featherless_key_here

# ── Agent credentials (Railway env vars → config/agent_config.yaml) ────────────
# Set these on Railway. The entrypoint.sh writes config/agent_config.yaml from them.
# Get each value from Band UI → Agents → (agent name) → Settings.
WARDEN_AGENT_ID=
WARDEN_API_KEY=

DATA_AGGREGATOR_AGENT_ID=
DATA_AGGREGATOR_API_KEY=

VENDOR_SYNC_AGENT_ID=
VENDOR_SYNC_API_KEY=

PAYOUT_BOT_AGENT_ID=
PAYOUT_BOT_API_KEY=

ROGUE_AGENT_ID=
ROGUE_API_KEY=

# ── Rogue A2A server ───────────────────────────────────────────────────────────
# Set ROGUE_AGENT_URL to the Railway public URL of the a2a-server service.
ROGUE_AGENT_URL=https://your-a2a-server.railway.app
BAND_BASE_URL=https://app.band.ai
